<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="64" author="katrinbe">
        <createSequence
                sequenceName="price_subscriptions_id_seq"
                startValue="1"
                incrementBy="50"/>
    </changeSet>

    <changeSet id="65" author="katrinbe">
        <createTable tableName="price_subscriptions">
            <column name="id" type="BIGINT"
                    defaultValueComputed="nextval('price_subscriptions_id_seq')">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="user_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_price_sub_user"
                             references="users(id)"/>
            </column>

            <column name="good_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_price_sub_good"
                             references="goods(id)"/>
            </column>

            <column name="shop_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_price_sub_shop"
                             references="shops(id)"/>
            </column>

            <column name="target_price" type="DECIMAL(10,2)">
                <constraints nullable="false"/>
            </column>

            <column name="created_at" type="TIMESTAMP"
                    defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <sql>
            ALTER SEQUENCE price_subscriptions_id_seq
                OWNED BY price_subscriptions.id;
        </sql>
    </changeSet>


    <changeSet id="66" author="katrinbe">
        <addUniqueConstraint
                tableName="price_subscriptions"
                columnNames="user_id, good_id, shop_id, target_price"
                constraintName="uq_price_subscription"/>
    </changeSet>


    <changeSet id="67" author="katrinbe">
        <createIndex tableName="price_subscriptions"
                     indexName="idx_price_sub_good_shop">
            <column name="good_id"/>
            <column name="shop_id"/>
        </createIndex>
    </changeSet>

    <!-- ═══════════════════════════════════════════════════════ -->


    <changeSet id="68" author="katrinbe">
        <createSequence
                sequenceName="availability_subscriptions_id_seq"
                startValue="1"
                incrementBy="50"/>
    </changeSet>


    <changeSet id="69" author="katrinbe">
        <createTable tableName="availability_subscriptions">
            <column name="id" type="BIGINT"
                    defaultValueComputed="nextval('availability_subscriptions_id_seq')">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="user_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_avail_sub_user"
                             references="users(id)"/>
            </column>

            <column name="good_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_avail_sub_good"
                             references="goods(id)"/>
            </column>


            <column name="shop_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_avail_sub_shop"
                             references="shops(id)"/>
            </column>

            <column name="created_at" type="TIMESTAMP"
                    defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <sql>
            ALTER SEQUENCE availability_subscriptions_id_seq
                OWNED BY availability_subscriptions.id;
        </sql>
    </changeSet>


    <changeSet id="70" author="katrinbe">
        <addUniqueConstraint
                tableName="availability_subscriptions"
                columnNames="user_id, good_id, shop_id"
                constraintName="uq_availability_subscription"/>
    </changeSet>

    <changeSet id="71" author="katrinbe">
        <createIndex tableName="availability_subscriptions"
                     indexName="idx_avail_sub_good_shop">
            <column name="good_id"/>
            <column name="shop_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>