<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="61" author="katrinbe">
        <createSequence
                sequenceName="outbox_events_id_seq"
                startValue="1"
                incrementBy="50"/>
    </changeSet>

    <changeSet id="62" author="katrinbe">
        <createTable tableName="outbox_events">
            <column name="id" type="BIGINT"
                    defaultValueComputed="nextval('outbox_events_id_seq')">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="topic" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="information" type="JSONB">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP"
                    defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="retry_count" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="error_message" type="TEXT">
                <constraints nullable="true"/>
            </column>
        </createTable>
        <sql>
            ALTER SEQUENCE outbox_events_id_seq OWNED BY outbox_events.id;
        </sql>
    </changeSet>

    <changeSet id="63" author="katrinbe">
        <createIndex tableName="outbox_events"
                     indexName="idx_outbox_retry_created">
            <column name="retry_count"/>
            <column name="created_at"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>