<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-configuration-3.0.dtd">
<hibernate-configuration>
    <session-factory>
<!--        выводит сгенериррованные sql запросы-->
        <property name="hibernate.show_sql">true</property>
        <property name="hibernate.jdbc.batch_size">75</property>
<!--        упорядочивание для батчинга, чтобы не прыгать с таблицы на таблицу-->
        <property name="hibernate.order_inserts">true</property>
        <property name="hibernate.order_updates">true</property>


        <mapping class="org.example.application.models.User" />
        <mapping class="org.example.application.models.Category" />
        <mapping class="org.example.application.models.Role" />
        <mapping class="org.example.application.models.Unit" />
        <mapping class="org.example.application.models.Good" />
        <mapping class="org.example.application.models.Price" />
        <mapping class="org.example.application.models.Shop" />
    <mapping class="org.example.application.models.District" />
            <mapping class="org.example.application.models.ModeratorRatingCheck" />
            <mapping class="org.example.application.models.Privilege" />
            <mapping class="org.example.application.models.RatingRecalculationLog" />
            <mapping class="org.example.application.models.Review" />
            <mapping class="org.example.application.models.Tag" />
            <mapping class="org.example.application.models.RefreshToken" />
            <mapping class="org.example.application.models.Favourite" />
    </session-factory>
</hibernate-configuration>
